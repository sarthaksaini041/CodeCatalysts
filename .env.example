SUPABASE_URL=your_supabase_project_url
SUPABASE_SECRET_KEY=your_supabase_secret_or_service_role_key
# Optional alias if you prefer naming the service credential explicitly:
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Browser-safe frontend config for the public site + admin portal:
VITE_SUPABASE_URL=your_supabase_project_url
# Supported names:
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
# VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_supabase_publishable_key
VITE_SUPABASE_STORAGE_BUCKET=content-media

# Optional if you run the frontend separately from the Vercel API in local development:
# VITE_API_BASE_URL=https://code-catalysts.vercel.app

# Optional server-side origin allowlist for /api/apply (comma-separated).
# Defaults already allow localhost:5173, 127.0.0.1:5173, and https://code-catalysts.vercel.app.
# APPLY_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
